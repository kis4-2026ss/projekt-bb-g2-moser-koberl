[raw_stderr] 
[raw_stderr]     order_lines: list[OrderItem] = []
[raw_stderr]     subtotal = Decimal("0.00")
[raw_stderr] 
[raw_stderr]     for cart_item in cart_items:
[raw_stderr]         product = db.get(Sneaker, cart_item.product_id)
[raw_stderr]         if product is None:
[raw_stderr]             raise HTTPException(
[raw_stderr]                 status_code=status.HTTP_400_BAD_REQUEST,
[raw_stderr]                 detail="Cart contains an unavailable product",
[raw_stderr]             )
[raw_stderr] 
[raw_stderr]         if cart_item.size not in product.sizes:
[raw_stderr]             raise HTTPException(
[raw_stderr]                 status_code=status.HTTP_400_BAD_REQUEST,
[raw_stderr]                 detail="Cart contains an unavailable product size",
[raw_stderr]             )
[raw_stderr] 
[raw_stderr]         if cart_item.quantity > product.stock:
[raw_stderr]             raise HTTPException(
[raw_stderr]                 status_code=status.HTTP_400_BAD_REQUEST,
[raw_stderr]                 detail="Cart quantity exceeds available stock",
[raw_stderr]             )
[raw_stderr] 
[raw_stderr]         line_total = product.price * cart_item.quantity
[raw_stderr]         subtotal += line_total
[raw_stderr]         order_lines.append(
[raw_stderr]             OrderItem(
[raw_stderr]                 product_id=product.id,
[raw_stderr]                 name_snapshot=product.name,
[raw_stderr]                 brand_snapshot=product.brand,
[raw_stderr]                 price_snapshot=product.price,
[raw_stderr]                 image_url_snapshot=product.image_url,
[raw_stderr]                 size=cart_item.size,
[raw_stderr]                 quantity=cart_item.quantity,
[raw_stderr]                 line_total=line_total,
[raw_stderr]             )
[raw_stderr]         )
[raw_stderr]         product.stock -= cart_item.quantity
[raw_stderr] 
[raw_stderr]     order = Order(
[raw_stderr]         status="created",
[raw_stderr]         shipping_name=payload.shipping.name,
[raw_stderr]         shipping_street=payload.shipping.street,
[raw_stderr]         shipping_zip=payload.shipping.zip,
[raw_stderr]         shipping_city=payload.shipping.city,
