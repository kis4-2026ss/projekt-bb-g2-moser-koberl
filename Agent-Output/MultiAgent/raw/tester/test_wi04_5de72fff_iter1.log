[raw_stderr]                 image_url=product.image_url,
[raw_stderr]                 size=stored_item.size,
[raw_stderr]                 quantity=stored_item.quantity,
[raw_stderr]                 line_total=line_total,
[raw_stderr]             )
[raw_stderr]         )
