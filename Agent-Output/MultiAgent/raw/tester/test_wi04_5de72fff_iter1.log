[raw_stderr] @router.post("", response_model=OrderCreated, status_code=status.HTTP_201_CREATED)
[raw_stderr] def create_order(
[raw_stderr]     payload: OrderCreate,
[raw_stderr]     db: Session = Depends(get_db),
[raw_stderr] ) -> OrderCreated:
