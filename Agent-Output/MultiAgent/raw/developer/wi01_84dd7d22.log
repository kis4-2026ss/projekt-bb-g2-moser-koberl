[raw_stderr] +def seed_sneakers(db: Session) -> int:
[raw_stderr] +    """Insert seed sneakers if they do not already exist."""
[raw_stderr] +    inserted = 0
[raw_stderr] +
[raw_stderr] +    for sneaker_data in SEED_SNEAKERS:
[raw_stderr] +        existing = db.execute(
[raw_stderr] +            select(Sneaker).where(
[raw_stderr] +                Sneaker.name == sneaker_data["name"],
[raw_stderr] +                Sneaker.brand == sneaker_data["brand"],
[raw_stderr] +            )
[raw_stderr] +        ).scalar_one_or_none()
[raw_stderr] +
[raw_stderr] +        if existing is not None:
[raw_stderr] +            continue
[raw_stderr] +
[raw_stderr] +        db.add(Sneaker(**sneaker_data))
[raw_stderr] +        inserted += 1
[raw_stderr] +
[raw_stderr] +    db.commit()
[raw_stderr] +    return inserted
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def run_seed() -> int:
[raw_stderr] +    """Initialize the database and seed catalog data."""
[raw_stderr] +    init_db()
[raw_stderr] +
[raw_stderr] +    with SessionLocal() as db:
[raw_stderr] +        return seed_sneakers(db)
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +if __name__ == "__main__":
[raw_stderr] +    created_count = run_seed()
[raw_stderr] +    print(f"Seed complete. Inserted {created_count} sneakers.")
