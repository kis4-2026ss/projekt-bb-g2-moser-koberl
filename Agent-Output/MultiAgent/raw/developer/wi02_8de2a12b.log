[raw_stderr] +
[raw_stderr] +
[raw_stderr] +@router.post(
[raw_stderr] +    "/items",
[raw_stderr] +    response_model=CartItemRead,
[raw_stderr] +    status_code=status.HTTP_201_CREATED,
