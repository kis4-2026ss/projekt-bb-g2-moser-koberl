[raw_stderr] +def add_cart_item(
[raw_stderr] +    payload: CartItemCreate,
[raw_stderr] +    db: Session = Depends(get_db),
[raw_stderr] +) -> CartItemRead:
[raw_stderr] +    """Add a product line to the cart or increase an existing line."""
[raw_stderr] +    product = _get_product(db, payload.product_id)
[raw_stderr] +
[raw_stderr] +    with _cart_lock:
[raw_stderr] +        existing = next(
[raw_stderr] +            (
[raw_stderr] +                item
[raw_stderr] +                for item in _cart_items.values()
[raw_stderr] +                if item.product_id == payload.product_id
[raw_stderr] +                and item.size == payload.size
[raw_stderr] +            ),
[raw_stderr] +            None,
[raw_stderr] +        )
[raw_stderr] +        requested_quantity = payload.quantity
[raw_stderr] +        if existing is not None:
[raw_stderr] +            requested_quantity += existing.quantity
[raw_stderr] +
[raw_stderr] +        _validate_cart_item(product, payload.size, requested_quantity)
[raw_stderr] +
[raw_stderr] +        if existing is None:
[raw_stderr] +            item_id = next(_cart_item_ids)
[raw_stderr] +            _cart_items[item_id] = StoredCartItem(
[raw_stderr] +                item_id=item_id,
[raw_stderr] +                product_id=payload.product_id,
[raw_stderr] +                size=payload.size,
[raw_stderr] +                quantity=payload.quantity,
[raw_stderr] +            )
[raw_stderr] +        else:
[raw_stderr] +            existing.quantity = requested_quantity
[raw_stderr] +            item_id = existing.item_id
[raw_stderr] +
[raw_stderr] +    cart = build_cart_response(db)
[raw_stderr] +    return next(item for item in cart.items if item.item_id == item_id)
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +@router.patch(
[raw_stderr] +    "/items/{item_id}",
[raw_stderr] +    status_code=status.HTTP_204_NO_CONTENT,
[raw_stderr] +    response_class=Response,
[raw_stderr] +)
[raw_stderr] +def update_cart_item(
[raw_stderr] +    item_id: int,
[raw_stderr] +    payload: CartItemUpdate,
[raw_stderr] +    db: Session = Depends(get_db),
[raw_stderr] +) -> Response:
