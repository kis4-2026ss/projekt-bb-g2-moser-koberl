[raw_stderr] +
[raw_stderr] +from backend.app.database import get_db
[raw_stderr] +from backend.app.models import Sneaker
[raw_stderr] +from backend.app.schemas import (
[raw_stderr] +    CartItemCreate,
[raw_stderr] +    CartItemRead,
[raw_stderr] +    CartItemUpdate,
[raw_stderr] +    CartRead,
[raw_stderr] +)
[raw_stderr] +
[raw_stderr] +router = APIRouter(prefix="/api/cart", tags=["cart"])
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +@dataclass
[raw_stderr] +class StoredCartItem:
[raw_stderr] +    """Minimal cart state stored between requests."""
[raw_stderr] +
[raw_stderr] +    item_id: int
[raw_stderr] +    product_id: int
[raw_stderr] +    size: str
[raw_stderr] +    quantity: int
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +_cart_items: dict[int, StoredCartItem] = {}
[raw_stderr] +_cart_item_ids = count(1)
[raw_stderr] +_cart_lock = Lock()
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def _get_product(db: Session, product_id: int) -> Sneaker:
[raw_stderr] +    """Return a product or raise a 404 HTTP error."""
[raw_stderr] +    product = db.get(Sneaker, product_id)
[raw_stderr] +    if product is None:
[raw_stderr] +        raise HTTPException(status_code=404, detail="Product not found")
[raw_stderr] +    return product
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def _validate_cart_item(product: Sneaker, size: str, quantity: int) -> None:
[raw_stderr] +    """Validate size and stock constraints for a cart line."""
[raw_stderr] +    if size not in product.sizes:
[raw_stderr] +        raise HTTPException(
[raw_stderr] +            status_code=status.HTTP_400_BAD_REQUEST,
[raw_stderr] +            detail="Selected size is not available for this product",
[raw_stderr] +        )
[raw_stderr] +
[raw_stderr] +    if quantity > product.stock:
[raw_stderr] +        raise HTTPException(
[raw_stderr] +            status_code=status.HTTP_400_BAD_REQUEST,
[raw_stderr] +            detail="Requested quantity exceeds available stock",
[raw_stderr] +        )
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def get_stored_cart_items() -> list[StoredCartItem]:
[raw_stderr] +    """Return a stable snapshot of the current cart state."""
[raw_stderr] +    with _cart_lock:
[raw_stderr] +        return list(_cart_items.values())
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def clear_cart() -> None:
[raw_stderr] +    """Remove all cart items after successful checkout."""
[raw_stderr] +    with _cart_lock:
[raw_stderr] +        _cart_items.clear()
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def build_cart_response(db: Session) -> CartRead:
[raw_stderr] +    """Build a cart response from stored cart lines and current products."""
[raw_stderr] +    response_items: list[CartItemRead] = []
[raw_stderr] +    subtotal = Decimal("0.00")
[raw_stderr] +
[raw_stderr] +    for stored_item in get_stored_cart_items():
[raw_stderr] +        product = db.get(Sneaker, stored_item.product_id)
[raw_stderr] +        if product is None:
[raw_stderr] +            continue
[raw_stderr] +
[raw_stderr] +        line_total = product.price * stored_item.quantity
[raw_stderr] +        subtotal += line_total
[raw_stderr] +        response_items.append(
[raw_stderr] +            CartItemRead(
[raw_stderr] +                item_id=stored_item.item_id,
[raw_stderr] +                product_id=product.id,
[raw_stderr] +                name=product.name,
[raw_stderr] +                brand=product.brand,
[raw_stderr] +                price=product.price,
[raw_stderr] +                currency=product.currency,
[raw_stderr] +                image_url=product.image_url,
[raw_stderr] +                size=stored_item.size,
[raw_stderr] +                quantity=stored_item.quantity,
[raw_stderr] +                line_total=line_total,
[raw_stderr] +            )
[raw_stderr] +        )
[raw_stderr] +
[raw_stderr] +    return CartRead(items=response_items, subtotal=subtotal, total=subtotal)
[raw_stderr] +
[raw_stderr] +
