[raw_stderr] +"""Shopping cart API endpoints.
[raw_stderr] +
[raw_stderr] +The architecture defines no cart table, so the cart is kept in process memory.
[raw_stderr] +This is suitable for the single-user demo frontend and keeps persistence scoped
[raw_stderr] +to the declared order schema.
[raw_stderr] +"""
[raw_stderr] +
[raw_stderr] +from dataclasses import dataclass
[raw_stderr] +from decimal import Decimal
[raw_stderr] +from itertools import count
[raw_stderr] +from threading import Lock
[raw_stderr] +
[raw_stderr] +from fastapi import APIRouter, Depends, HTTPException, Response, status
