[raw_stderr] +_cart_lock = Lock()
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def _get_product(db: Session, product_id: int) -> Sneaker:
[raw_stderr] +    """Return a product or raise a 404 HTTP error."""
[raw_stderr] +    product = db.get(Sneaker, product_id)
[raw_stderr] +    if product is None:
[raw_stderr] +        raise HTTPException(status_code=404, detail="Product not found")
[raw_stderr] +    return product
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def _validate_cart_item(product: Sneaker, size: str, quantity: int) -> None:
[raw_stderr] +    """Validate size and stock constraints for a cart line."""
[raw_stderr] +    if size not in product.sizes:
[raw_stderr] +        raise HTTPException(
[raw_stderr] +            status_code=status.HTTP_400_BAD_REQUEST,
[raw_stderr] +            detail="Selected size is not available for this product",
[raw_stderr] +        )
[raw_stderr] +
[raw_stderr] +    if quantity > product.stock:
[raw_stderr] +        raise HTTPException(
[raw_stderr] +            status_code=status.HTTP_400_BAD_REQUEST,
[raw_stderr] +            detail="Requested quantity exceeds available stock",
[raw_stderr] +        )
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def get_stored_cart_items() -> list[StoredCartItem]:
[raw_stderr] +    """Return a stable snapshot of the current cart state."""
[raw_stderr] +    with _cart_lock:
[raw_stderr] +        return list(_cart_items.values())
[raw_stderr] +
[raw_stderr] +
