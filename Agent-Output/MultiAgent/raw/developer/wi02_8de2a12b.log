[raw_stderr] +
[raw_stderr] +def build_cart_response(db: Session) -> CartRead:
[raw_stderr] +    """Build a cart response from stored cart lines and current products."""
[raw_stderr] +    response_items: list[CartItemRead] = []
[raw_stderr] +    subtotal = Decimal("0.00")
[raw_stderr] +
[raw_stderr] +    for stored_item in get_stored_cart_items():
[raw_stderr] +        product = db.get(Sneaker, stored_item.product_id)
[raw_stderr] +        if product is None:
