[raw_stderr] +    return product
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def _validate_cart_item(product: Sneaker, size: str, quantity: int) -> None:
[raw_stderr] +    """Validate size and stock constraints for a cart line."""
[raw_stderr] +    if size not in product.sizes:
[raw_stderr] +        raise HTTPException(
