[raw_stderr] +        if stored_item is None:
[raw_stderr] +            raise HTTPException(status_code=404, detail="Cart item not found")
[raw_stderr] +
[raw_stderr] +        product = _get_product(db, stored_item.product_id)
[raw_stderr] +        _validate_cart_item(product, stored_item.size, payload.quantity)
[raw_stderr] +        stored_item.quantity = payload.quantity
[raw_stderr] +
[raw_stderr] +    return Response(status_code=status.HTTP_204_NO_CONTENT)
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +@router.delete(
