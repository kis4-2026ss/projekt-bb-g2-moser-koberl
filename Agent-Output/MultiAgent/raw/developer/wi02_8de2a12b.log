[raw_stderr] +    with _cart_lock:
[raw_stderr] +        existing = next(
[raw_stderr] +            (
[raw_stderr] +                item
[raw_stderr] +                for item in _cart_items.values()
[raw_stderr] +                if item.product_id == payload.product_id
[raw_stderr] +                and item.size == payload.size
[raw_stderr] +            ),
[raw_stderr] +            None,
[raw_stderr] +        )
[raw_stderr] +        requested_quantity = payload.quantity
[raw_stderr] +        if existing is not None:
[raw_stderr] +            requested_quantity += existing.quantity
[raw_stderr] +
[raw_stderr] +        _validate_cart_item(product, payload.size, requested_quantity)
[raw_stderr] +
[raw_stderr] +        if existing is None:
