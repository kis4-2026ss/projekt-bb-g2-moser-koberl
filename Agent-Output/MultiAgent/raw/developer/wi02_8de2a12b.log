[raw_stderr] +            detail="Selected size is not available for this product",
[raw_stderr] +        )
[raw_stderr] +
[raw_stderr] +    if quantity > product.stock:
[raw_stderr] +        raise HTTPException(
[raw_stderr] +            status_code=status.HTTP_400_BAD_REQUEST,
[raw_stderr] +            detail="Requested quantity exceeds available stock",
[raw_stderr] +        )
[raw_stderr] +
[raw_stderr] +
