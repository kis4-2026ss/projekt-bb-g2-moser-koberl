[raw_stderr] +
[raw_stderr] +async function request(path, options = {}) {
[raw_stderr] +  const response = await fetch(path, options);
[raw_stderr] +  if (response.status === 204) {
[raw_stderr] +    return null;
[raw_stderr] +  }
[raw_stderr] +
[raw_stderr] +  const data = await response.json().catch(() => ({}));
[raw_stderr] +  if (!response.ok) {
[raw_stderr] +    throw new Error(data.detail || "Die Anfrage konnte nicht verarbeitet werden.");
[raw_stderr] +  }
[raw_stderr] +  return data;
[raw_stderr] +}
