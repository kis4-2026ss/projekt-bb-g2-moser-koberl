[raw_stderr] +const JSON_HEADERS = { "Content-Type": "application/json" };
[raw_stderr] +
[raw_stderr] +export const api = {
[raw_stderr] +  async get(path) {
[raw_stderr] +    return request(path);
[raw_stderr] +  },
[raw_stderr] +
[raw_stderr] +  async post(path, payload) {
[raw_stderr] +    return request(path, {
[raw_stderr] +      method: "POST",
[raw_stderr] +      headers: JSON_HEADERS,
[raw_stderr] +      body: JSON.stringify(payload),
[raw_stderr] +    });
[raw_stderr] +  },
[raw_stderr] +
[raw_stderr] +  async patch(path, payload) {
[raw_stderr] +    return request(path, {
[raw_stderr] +      method: "PATCH",
[raw_stderr] +      headers: JSON_HEADERS,
[raw_stderr] +      body: JSON.stringify(payload),
[raw_stderr] +    });
[raw_stderr] +  },
[raw_stderr] +
[raw_stderr] +  async delete(path) {
[raw_stderr] +    return request(path, { method: "DELETE" });
[raw_stderr] +  },
[raw_stderr] +};
[raw_stderr] +
[raw_stderr] +async function request(path, options = {}) {
[raw_stderr] +  const response = await fetch(path, options);
[raw_stderr] +  if (response.status === 204) {
[raw_stderr] +    return null;
[raw_stderr] +  }
[raw_stderr] +
[raw_stderr] +  const data = await response.json().catch(() => ({}));
[raw_stderr] +  if (!response.ok) {
[raw_stderr] +    throw new Error(data.detail || "Die Anfrage konnte nicht verarbeitet werden.");
[raw_stderr] +  }
[raw_stderr] +  return data;
[raw_stderr] +}
[raw_stderr] +
[raw_stderr] +export function formatMoney(value, currency = "EUR") {
[raw_stderr] +  return new Intl.NumberFormat("de-DE", {
[raw_stderr] +    style: "currency",
[raw_stderr] +    currency,
[raw_stderr] +  }).format(Number(value || 0));
[raw_stderr] +}
[raw_stderr] +
[raw_stderr] +export function escapeHtml(value) {
[raw_stderr] +  return String(value ?? "")
[raw_stderr] +    .replaceAll("&", "&amp;")
[raw_stderr] +    .replaceAll("<", "&lt;")
[raw_stderr] +    .replaceAll(">", "&gt;")
[raw_stderr] +    .replaceAll('"', "&quot;")
[raw_stderr] +    .replaceAll("'", "&#039;");
[raw_stderr] +}
