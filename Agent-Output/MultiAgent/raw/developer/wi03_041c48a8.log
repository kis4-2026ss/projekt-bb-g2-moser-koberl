[raw_stderr] +"""Review API endpoints."""
[raw_stderr] +
[raw_stderr] +from fastapi import APIRouter, Depends, HTTPException, status
[raw_stderr] +from sqlalchemy import func, select
[raw_stderr] +from sqlalchemy.orm import Session
[raw_stderr] +
[raw_stderr] +from backend.app.database import get_db
[raw_stderr] +from backend.app.models import Review, Sneaker
[raw_stderr] +from backend.app.schemas import ProductReviewsRead, ReviewCreate, ReviewRead
[raw_stderr] +
[raw_stderr] +router = APIRouter(prefix="/api/products", tags=["reviews"])
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def _get_product(db: Session, product_id: int) -> Sneaker:
[raw_stderr] +    """Return a product or raise a 404 HTTP error."""
[raw_stderr] +    product = db.get(Sneaker, product_id)
[raw_stderr] +    if product is None:
[raw_stderr] +        raise HTTPException(status_code=404, detail="Product not found")
[raw_stderr] +    return product
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +def _refresh_product_rating(db: Session, product: Sneaker) -> None:
[raw_stderr] +    """Persist the rounded average rating on the product record."""
[raw_stderr] +    average = db.scalar(
[raw_stderr] +        select(func.avg(Review.rating)).where(Review.product_id == product.id)
[raw_stderr] +    )
[raw_stderr] +    product.rating = round(float(average or 0), 1)
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +@router.get("/{product_id}/reviews", response_model=ProductReviewsRead)
[raw_stderr] +def list_reviews(
[raw_stderr] +    product_id: int,
[raw_stderr] +    db: Session = Depends(get_db),
[raw_stderr] +) -> ProductReviewsRead:
[raw_stderr] +    """Return review aggregate and reviews for one product."""
[raw_stderr] +    _get_product(db, product_id)
[raw_stderr] +    reviews = list(
[raw_stderr] +        db.scalars(
[raw_stderr] +            select(Review)
[raw_stderr] +            .where(Review.product_id == product_id)
[raw_stderr] +            .order_by(Review.created_at.desc(), Review.id.desc())
[raw_stderr] +        ).all()
[raw_stderr] +    )
[raw_stderr] +    average = (
[raw_stderr] +        sum(review.rating for review in reviews) / len(reviews)
[raw_stderr] +        if reviews
[raw_stderr] +        else 0.0
[raw_stderr] +    )
[raw_stderr] +    return ProductReviewsRead(
[raw_stderr] +        average_rating=round(average, 1),
[raw_stderr] +        reviews=reviews,
[raw_stderr] +    )
[raw_stderr] +
[raw_stderr] +
[raw_stderr] +@router.post(
[raw_stderr] +    "/{product_id}/reviews",
[raw_stderr] +    response_model=ReviewRead,
[raw_stderr] +    status_code=status.HTTP_201_CREATED,
[raw_stderr] +)
[raw_stderr] +def create_review(
[raw_stderr] +    product_id: int,
[raw_stderr] +    payload: ReviewCreate,
[raw_stderr] +    db: Session = Depends(get_db),
[raw_stderr] +) -> Review:
[raw_stderr] +    """Create a review for a product and update its aggregate rating."""
[raw_stderr] +    product = _get_product(db, product_id)
[raw_stderr] +    review = Review(
[raw_stderr] +        product_id=product.id,
[raw_stderr] +        author=payload.author,
[raw_stderr] +        rating=payload.rating,
[raw_stderr] +        comment=payload.comment,
[raw_stderr] +    )
[raw_stderr] +    db.add(review)
[raw_stderr] +    db.flush()
[raw_stderr] +    _refresh_product_rating(db, product)
[raw_stderr] +    db.commit()
[raw_stderr] +    db.refresh(review)
[raw_stderr] +    return review
